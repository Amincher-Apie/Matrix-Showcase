stateDiagram-v2
    [*] --> MainMenu
    MainMenu --> Lobby
    Lobby --> HeroSelect
    HeroSelect --> RunInit

    RunInit --> BuildMissionInput
    BuildMissionInput --> GeneratePCG
    GeneratePCG --> BindMissionRooms
    BindMissionRooms --> SpawnPlayers
    SpawnPlayers --> Exploring

    Exploring --> RoomEnter: player enters room
    RoomEnter --> Exploring: normal room
    RoomEnter --> BossFight: boss room

    Exploring --> RunDefeat: all players dead
    BossFight --> RunDefeat: all players dead
    BossFight --> RunVictory: BossDefeated

    RunVictory --> RunSummary
    RunDefeat --> RunSummary
    RunSummary --> MainMenu

